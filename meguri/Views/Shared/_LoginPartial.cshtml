@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<div class="home">
    <div>
    @if (SignInManager.IsSignedIn(User)) {
      <a asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">@L["Hello"] @User.Identity?.Name!</a>
      <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
        <button type="submit">@L["Logout"]</button>
      </form>
    } else {
      <a asp-area="Identity" asp-page="/Account/Register">@L["Register"]</a>
      <a asp-area="Identity" asp-page="/Account/Login">@L["Login"]</a>
    }
    </div>
</div>