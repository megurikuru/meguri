@model Meguri.Models.Work

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Work</h4>
<hr />
<div>
    <div>
        <form asp-action="Edit" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="UserId" />
            <div>
                <label asp-for="Name"></label>
                <input asp-for="Name" />
                <span asp-validation-for="Name"></span>
            </div>
            <div>
                <label asp-for="Text"></label>
                <input asp-for="Text" />
                <span asp-validation-for="Text"></span>
            </div>
            <div>
                <label asp-for="ParentId"></label>
                <input asp-for="ParentId" />
                <span asp-validation-for="ParentId"></span>
            </div>
            <div>
                <label asp-for="WorkType"></label>
                <input asp-for="WorkType" />
                <span asp-validation-for="WorkType"></span>
            </div>
            <div>
                <label asp-for="CategoryId"></label>
                <input asp-for="CategoryId" />
                <span asp-validation-for="CategoryId"></span>
            </div>
            <div>
                <label asp-for="Tag1"></label>
                <input asp-for="Tag1" />
                <span asp-validation-for="Tag1"></span>
            </div>
            <div>
                <label asp-for="Tag2"></label>
                <input asp-for="Tag2" />
                <span asp-validation-for="Tag2"></span>
            </div>
            <div>
                <label asp-for="Tag3"></label>
                <input asp-for="Tag3" />
                <span asp-validation-for="Tag3"></span>
            </div>
            <div>
                <label asp-for="FileContent"></label>
                @if (Model.FileContent != null) {
                    <div>
                        @{
                            var image = Convert.ToBase64String(Model.FileContent);
                        }
                        <img src="data:image/png;base64,@image">
                    </div>
                }
                <input asp-for="FileContent" type="file" />
                <span asp-validation-for="FileContent"></span>
            </div>
            <div>
                <label>
                    <input asp-for="Sexual" /> @Html.DisplayNameFor(model => model.Sexual)
                </label>
            </div>
            <div>
                <label>
                    <input asp-for="Violence" /> @Html.DisplayNameFor(model => model.Violence)
                </label>
            </div>
            @*
            <div>
                <label asp-for="Created"></label>
                <input asp-for="Created" />
                <span asp-validation-for="Created"></span>
            </div>
            <div>
                <label asp-for="Updated"></label>
                <input asp-for="Updated" />
                <span asp-validation-for="Updated"></span>
            </div>
            *@
            <div>
                <input type="submit" value="Save" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
